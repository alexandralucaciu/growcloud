# Growcloud Environment Configuration Example
# Copy this file to .env and fill in your values.

# Set to "false" to attempt live fetch, "true" to use local mock data
VITE_USE_MOCK_DATA="false"

# Your ThingsBoard instance URL (e.g., https://demo.thingsboard.io or a local IP)
VITE_THINGSBOARD_SERVER_URL="https://eu.thingsboard.cloud"

# Device access token from ThingsBoard
VITE_THINGSBOARD_DEVICE_TOKEN="2f815460-54fd-11f1-be5a-b9befc3a4888"
